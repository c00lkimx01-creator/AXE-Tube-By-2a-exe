{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/watch", "dest": "/index.html" },
    { "src": "/shorts/(.*)", "dest": "/index.html" },
    { "src": "/search", "dest": "/index.html" },
    { "src": "/channel/(.*)", "dest": "/index.html" },
    { "src": "/feed/(.*)", "dest": "/index.html" },
    { "src": "/setting(s)?", "dest": "/index.html" },
    { "src": "/home", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}